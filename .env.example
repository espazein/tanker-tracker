PORT=3000
ADMIN_PIN=your_secure_pin_here
SOCIETY_NAME=My Society
# Tells Node + SQLite how to interpret EXIF naive timestamps and group
# daily-trend buckets. Defaults to Asia/Kolkata if unset.
TZ=Asia/Kolkata

# HTTPS / domain (leave DOMAIN blank to stay on plain HTTP).
# Geolocation/geofencing only works over HTTPS, so set these in production.
DOMAIN=
SSL_EMAIL=
